# ─── Server Configuration ───
PORT=5000
NODE_ENV=development

# ─── MongoDB Connection ───
# Use MongoDB Atlas for production and URL-encode special characters in the password.
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/fingerprint_attendance?retryWrites=true&w=majority

# ─── JWT Secret (change this in production!) ───
JWT_SECRET=your_super_secret_jwt_key_change_this

# ─── Admin Default Credentials (used by seed script) ───
ADMIN_EMAIL=admin@attendance.com
ADMIN_PASSWORD=Admin@123

# ─── CORS Origin (frontend URL) ───
# Development: http://localhost:5173
# Production: https://fingerprint-attendance-system-mtcgwimxi-mandeep21ss-projects.vercel.app
CLIENT_URL=https://fingerprint-attendance-system-mtcgwimxi-mandeep21ss-projects.vercel.app
