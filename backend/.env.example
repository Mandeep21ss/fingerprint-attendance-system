# Copy to .env and fill in real values. Never commit .env.

# ─── Server ───
PORT=5000
NODE_ENV=development

# ─── MongoDB (required) ───
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/fingerprint_attendance?retryWrites=true&w=majority

# ─── JWT (required) — use a long random string in production ───
JWT_SECRET=change_me_to_a_long_random_string

# ─── Default admin (used by POST /api/auth/seed and npm run seed) ───
ADMIN_EMAIL=admin@attendance.com
ADMIN_PASSWORD=ChangeThisSecurePassword

# ─── CORS + Socket.io — frontend origin(s), comma-separated if needed ───
# Examples:
#   http://localhost:5173
#   https://your-app.vercel.app,http://localhost:5173
CLIENT_URL=http://localhost:5173

# ─── Production seed protection (required when NODE_ENV=production) ───
# POST /api/auth/seed must include header: x-seed-secret: <same value>
SEED_SECRET=generate_a_random_secret_for_one_time_seed_calls
